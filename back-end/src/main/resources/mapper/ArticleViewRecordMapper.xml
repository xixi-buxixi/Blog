<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.blog.mapper.ArticleViewRecordMapper">

    <resultMap id="BaseResultMap" type="com.blog.entity.ArticleViewRecord">
        <id column="id" property="id"/>
        <result column="article_id" property="articleId"/>
        <result column="user_id" property="userId"/>
        <result column="ip_address" property="ipAddress"/>
        <result column="view_time" property="viewTime"/>
    </resultMap>

    <!-- 检查登录用户是否已浏览 -->
    <select id="existsByArticleIdAndUserId" resultType="boolean">
        SELECT COUNT(*) > 0
        FROM t_article_view_record
        WHERE article_id = #{articleId} AND user_id = #{userId}
    </select>

    <!-- 检查IP是否已浏览 -->
    <select id="existsByArticleIdAndIpAddress" resultType="boolean">
        SELECT COUNT(*) > 0
        FROM t_article_view_record
        WHERE article_id = #{articleId} AND ip_address = #{ipAddress}
    </select>

    <!-- 清理过期记录 -->
    <delete id="deleteByViewTimeBefore">
        DELETE FROM t_article_view_record
        WHERE view_time &lt; #{beforeTime}
    </delete>

</mapper>