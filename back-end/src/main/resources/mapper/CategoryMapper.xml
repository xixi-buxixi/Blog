<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.blog.mapper.CategoryMapper">

    <resultMap id="BaseResultMap" type="com.blog.entity.Category">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <!-- 分类VO映射 -->
    <resultMap id="CategoryVOMap" type="com.blog.vo.CategoryVO">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="article_count" property="articleCount"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <!-- 查询所有分类(包含文章数量) -->
    <select id="selectCategoryListWithArticleCount" resultMap="CategoryVOMap">
        SELECT
            c.id,
            c.name,
            c.description,
            c.sort_order,
            c.create_time,
            (SELECT COUNT(*) FROM t_article a WHERE a.category_id = c.id AND a.deleted = 0 AND a.status = 1) AS article_count
        FROM t_category c
        ORDER BY c.sort_order ASC, c.create_time ASC
    </select>

</mapper>