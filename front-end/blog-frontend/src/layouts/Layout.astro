---
// Layout 组件 - 页面基础布局
interface Props {
  title?: string;
  description?: string;
}

const { title = 'TECH::minimal', description = 'Clean, bright, minimal aesthetic, code-first focus tech blog.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Lora:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col relative antialiased bg-white text-slate-800">
    <!-- Subtle Geometric Lines Background -->
    <div class="fixed inset-0 pointer-events-none z-[-1] opacity-20">
      <svg class="absolute inset-0 w-full h-full" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid-pattern" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#cbd5e1" stroke-width="0.5" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid-pattern)" />
      </svg>
    </div>
    
    <slot />

  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>