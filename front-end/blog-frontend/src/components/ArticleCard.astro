---
// ArticleCard 组件 - 文章卡片
import type { Article } from '../utils/api';

interface Props {
  article: Article;
}

const { article } = Astro.props;

// 格式化日期
const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
---

<article class="bg-white rounded-xl border border-gray-100 overflow-hidden hover:shadow-lg hover:border-primary-100 transition-all duration-300 group">
  <a href={`/article/${article.id}`} class="block">
    <!-- 封面图 -->
    {article.coverImage && (
      <div class="aspect-video overflow-hidden bg-gray-100">
        <img
          src={article.coverImage}
          alt={article.title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      </div>
    )}

    <!-- 内容 -->
    <div class="p-5">
      <!-- 分类标签 -->
      <div class="flex items-center space-x-2 mb-3">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary-50 text-primary-600">
          {article.categoryName}
        </span>
      </div>

      <!-- 标题 -->
      <h2 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-primary-600 transition-colors line-clamp-2">
        {article.title}
      </h2>

      <!-- 摘要 -->
      {article.summary && (
        <p class="text-gray-500 text-sm mb-4 line-clamp-2">
          {article.summary}
        </p>
      )}

      <!-- 元信息 -->
      <div class="flex items-center justify-between text-xs text-gray-400">
        <time datetime={article.createTime}>
          {formatDate(article.createTime)}
        </time>
        <div class="flex items-center space-x-3">
          <span class="flex items-center space-x-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
            <span>{article.viewCount}</span>
          </span>
        </div>
      </div>
    </div>
  </a>
</article>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>