---
// Header 组件 - 顶部导航栏
interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;

const navItems = [
  { href: '/', label: '/home' },
  { href: '/category', label: '/category' },
  { href: '/archive', label: '/archive' },
];

const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
};
---

<nav class="fixed top-0 w-full z-50 glass border-b-0 px-6 py-4 flex justify-between items-center transition-transform duration-300" id="navbar">
  <a href="/" class="font-display font-bold text-xl tracking-tight flex items-center gap-2 hover-trigger">
    <span class="w-2 h-2 rounded-full bg-secondary animate-pulse"></span>
    SYS<span class="text-primary">.LOG</span>
  </a>
  <div class="hidden md:flex font-mono text-sm gap-8 text-zinc-400">
    {navItems.map((item) => (
      <a
        href={item.href}
        class={`transition-colors hover-trigger ${
          isActive(item.href)
            ? 'text-white'
            : 'hover:text-white'
        }`}
      >
        {item.label}
      </a>
    ))}
  </div>
  <div class="flex items-center gap-4">
    <a href="/search" class="text-zinc-400 hover:text-white hover-trigger flex items-center justify-center w-8 h-8 rounded-full bg-white/5 transition-colors">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
    </a>
    <button class="md:hidden text-zinc-400 hover:text-white hover-trigger" id="mobile-menu-btn" aria-label="Toggle Menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>
</nav>

<!-- Mobile Navigation -->
<div id="mobile-menu" class="hidden fixed inset-0 z-40 bg-background/95 backdrop-blur-xl pt-24 px-6 md:hidden">
  <nav class="flex flex-col gap-6 font-mono text-lg">
    {navItems.map((item) => (
      <a
        href={item.href}
        class={`block py-2 border-b border-white/10 hover-trigger ${
          isActive(item.href)
            ? 'text-white border-primary/50'
            : 'text-zinc-400 hover:text-white'
        }`}
      >
        {item.label}
      </a>
    ))}
    <form action="/search" method="get" class="relative mt-8">
      <input
        type="text"
        name="q"
        placeholder="Search..."
        class="w-full bg-black/50 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors hover-trigger placeholder:text-zinc-600 font-sans"
      />
    </form>
  </nav>
</div>

<script>
  // Mobile Menu Logic
  const initMenu = () => {
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    const toggleMenu = () => {
      mobileMenu?.classList.toggle('hidden');
    };

    menuBtn?.addEventListener('click', toggleMenu);

    return () => {
      menuBtn?.removeEventListener('click', toggleMenu);
    };
  };

  // Navbar hide/show on scroll
  const initNavbarScroll = () => {
    let lastScroll = 0;
    const navbar = document.getElementById('navbar');
    
    const handleScroll = () => {
      const currentScroll = window.scrollY;
      
      if (navbar) {
        if (currentScroll > 50 && currentScroll > lastScroll) {
          navbar.style.transform = 'translateY(-100%)';
        } else {
          navbar.style.transform = 'translateY(0)';
        }
      }
      
      lastScroll = currentScroll;
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    
    return () => {
      window.removeEventListener('scroll', handleScroll);
    };
  };

  let cleanupMenu: (() => void) | undefined;
  let cleanupScroll: (() => void) | undefined;

  const init = () => {
    cleanupMenu = initMenu();
    cleanupScroll = initNavbarScroll();
  };

  init();

  document.addEventListener('astro:page-load', () => {
    if(cleanupMenu) cleanupMenu();
    if(cleanupScroll) cleanupScroll();
    init();
  });
</script>