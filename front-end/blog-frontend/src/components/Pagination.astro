---
// Pagination 组件 - 分页
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;

// 生成页码数组
const getPageNumbers = () => {
  const pages: (number | string)[] = [];

  if (totalPages <= 7) {
    for (let i = 1; i <= totalPages; i++) {
      pages.push(i);
    }
  } else {
    if (currentPage <= 3) {
      pages.push(1, 2, 3, 4, '...', totalPages);
    } else if (currentPage >= totalPages - 2) {
      pages.push(1, '...', totalPages - 3, totalPages - 2, totalPages - 1, totalPages);
    } else {
      pages.push(1, '...', currentPage - 1, currentPage, currentPage + 1, '...', totalPages);
    }
  }

  return pages;
};

const buildUrl = (page: number) => {
  const url = new URL(baseUrl, 'http://example.com');
  url.searchParams.set('page', String(page));
  return url.pathname + url.search;
};

const pageNumbers = getPageNumbers();
---

{totalPages > 1 && (
  <nav class="flex items-center justify-center space-x-4 font-mono" aria-label="分页导航">
    <!-- 上一页 -->
    {currentPage > 1 ? (
      <a
        href={buildUrl(currentPage - 1)}
        class="flex items-center px-4 py-2 text-sm text-zinc-400 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 hover:text-white transition-colors hover-trigger"
      >
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        PREV
      </a>
    ) : (
      <span class="flex items-center px-4 py-2 text-sm text-zinc-600 border border-white/5 rounded-xl cursor-not-allowed">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        PREV
      </span>
    )}

    <!-- 页码 -->
    <div class="hidden sm:flex items-center space-x-2">
      {pageNumbers.map((page) => (
        typeof page === 'number' ? (
          <a
            href={buildUrl(page)}
            class={`w-10 h-10 flex items-center justify-center text-sm rounded-xl border transition-colors hover-trigger ${
              page === currentPage
                ? 'bg-primary/20 text-primary border-primary/50'
                : 'text-zinc-400 border-white/10 hover:bg-white/10 hover:text-white'
            }`}
            aria-current={page === currentPage ? 'page' : undefined}
          >
            {page}
          </a>
        ) : (
          <span class="px-2 py-2 text-zinc-600">...</span>
        )
      ))}
    </div>

    <!-- 当前页/总页数 (移动端) -->
    <span class="sm:hidden px-3 py-2 text-sm text-zinc-500">
      {currentPage} / {totalPages}
    </span>

    <!-- 下一页 -->
    {currentPage < totalPages ? (
      <a
        href={buildUrl(currentPage + 1)}
        class="flex items-center px-4 py-2 text-sm text-zinc-400 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 hover:text-white transition-colors hover-trigger"
      >
        NEXT
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    ) : (
      <span class="flex items-center px-4 py-2 text-sm text-zinc-600 border border-white/5 rounded-xl cursor-not-allowed">
        NEXT
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    )}
  </nav>
)}