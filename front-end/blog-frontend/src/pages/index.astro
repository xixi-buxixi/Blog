---
// 首页 - 具有Awwwards设计风格的作品集展示
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Pagination from '../components/Pagination.astro';
import { articleApi, categoryApi, type Article, type Category } from '../utils/api';

// 获取查询参数
const url = new URL(Astro.request.url);
const page = parseInt(url.searchParams.get('page') || '1');
const categoryId = url.searchParams.get('category') ? parseInt(url.searchParams.get('category')!) : undefined;
const pageSize = 10;

// 获取文章列表和分类列表
let articles: Article[] = [];
let categories: Category[] = [];
let total = 0;
let totalPages = 1;

try {
  const [articlesRes, categoriesRes] = await Promise.all([
    articleApi.getList({ page, pageSize, categoryId }),
    categoryApi.getList()
  ]);
  articles = articlesRes.data.records;
  total = articlesRes.data.total;
  totalPages = articlesRes.data.pages;
  categories = categoriesRes.data;
} catch (error) {
  console.error('Failed to fetch data:', error);
}

const selectedCategory = categoryId ? categories.find(c => c.id === categoryId) : null;
---

<Layout title={selectedCategory ? `${selectedCategory.name} - Selected Works` : 'Selected Works - Awwwards Designer'}>
  <Header currentPath={Astro.url.pathname} />

  <main class="flex-1 bg-white overflow-hidden">
    <!-- Hero Section (Parallax) -->
    <section class="min-h-screen w-full flex flex-col justify-center px-4 sm:px-10 md:px-20 relative pt-32 pb-20">
      <div class="max-w-[1400px] mx-auto w-full relative z-10 flex-1 flex flex-col justify-center">
        <h1 class="font-serif text-[12vw] leading-[0.9] tracking-tighter text-black uppercase block hero-title" id="parallax-text-1">
          Awwwards
        </h1>
        <h1 class="font-serif text-[12vw] leading-[0.9] tracking-tighter text-black uppercase block text-right hero-title mt-4" id="parallax-text-2">
          Nominated
        </h1>
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mt-12 md:mt-24 gap-10 md:gap-0">
          <p class="font-mono text-primary-500 uppercase tracking-widest text-sm md:text-base max-w-sm leading-relaxed">
            Crafting digital experiences with strict aesthetic precision and dynamic motion.
          </p>
          <h1 class="font-serif text-[12vw] leading-[0.9] tracking-tighter text-black uppercase hero-title" id="parallax-text-3">
            Designer
          </h1>
        </div>
      </div>
      
      <!-- Scroll indicator -->
      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center">
        <span class="font-mono text-xs tracking-widest uppercase mb-4 text-black">Scroll to explore</span>
        <div class="w-[1px] h-16 bg-black/10 relative overflow-hidden">
          <div class="w-full h-full bg-primary-500 absolute top-0 left-0 animate-[scrollDown_2s_ease-in-out_infinite]"></div>
        </div>
      </div>
    </section>

    <div class="max-w-[1400px] mx-auto px-4 sm:px-10 md:px-20 py-32">
      <!-- 分类筛选 -->
      <div class="mb-24 flex flex-col md:flex-row justify-between items-start md:items-end border-b border-black/10 pb-10">
        <h2 class="font-serif text-4xl md:text-6xl text-black mb-10 md:mb-0 tracking-tight">Selected Works</h2>
        <div class="flex flex-wrap items-center gap-6">
          <a
            href="/"
            class={`font-mono text-sm tracking-widest uppercase transition-colors hover-target ${
              !categoryId
                ? 'text-primary-500 border-b border-primary-500 pb-1'
                : 'text-black/50 hover:text-black pb-1'
            }`}
          >
            All
          </a>
          {categories.map((category) => (
            <a
              href={`/?category=${category.id}`}
              class={`font-mono text-sm tracking-widest uppercase transition-colors hover-target ${
                categoryId === category.id
                  ? 'text-primary-500 border-b border-primary-500 pb-1'
                  : 'text-black/50 hover:text-black pb-1'
              }`}
            >
              {category.name}
            </a>
          ))}
        </div>
      </div>

      <!-- 作品列表 -->
      {articles?.length > 0 ? (
        <div class="flex flex-col gap-10">
          {articles.map((article, index) => (
            <ArticleCard article={article} index={index} />
          ))}
        </div>
      ) : (
        <div class="text-center py-32">
          <p class="font-mono text-black/50 tracking-widest uppercase text-xl">No works found</p>
          {!categoryId && (
            <p class="text-primary-500 text-sm mt-4 font-mono">Backend service might be offline.</p>
          )}
        </div>
      )}

      <!-- 分页 -->
      {totalPages > 1 && (
        <div class="mt-20 border-t border-black/10 pt-10">
          <Pagination
            currentPage={page}
            totalPages={totalPages}
            baseUrl={categoryId ? `/?category=${categoryId}` : '/'}
          />
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>

<style>
  @keyframes scrollDown {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100%); }
  }
</style>

<script>
  // Parallax Scroll Effect
  const initParallax = () => {
    const text1 = document.getElementById('parallax-text-1');
    const text2 = document.getElementById('parallax-text-2');
    const text3 = document.getElementById('parallax-text-3');
    
    const handleScroll = () => {
      const scrolled = window.scrollY;
      
      // Move left to right
      if (text1) text1.style.transform = `translateX(${scrolled * 0.15}px)`;
      // Move right to left
      if (text2) text2.style.transform = `translateX(${scrolled * -0.2}px)`;
      // Move up slightly
      if (text3) text3.style.transform = `translateY(${scrolled * -0.08}px)`;
    };

    window.addEventListener('scroll', handleScroll);
    
    // Cleanup
    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', handleScroll);
    });
  };

  initParallax();
  document.addEventListener('astro:page-load', initParallax);
</script>