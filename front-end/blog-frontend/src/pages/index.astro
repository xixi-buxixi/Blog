---
// 首页 - 极简阅读风格
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArticleList from '../components/ArticleList';
import { categoryApi, type Category } from '../utils/api';

// 获取查询参数
const url = new URL(Astro.request.url);
const page = parseInt(url.searchParams.get('page') || '1');
const categoryId = url.searchParams.get('category') ? parseInt(url.searchParams.get('category')!) : undefined;
const pageSize = 10;

// 只获取分类列表（文章通过客户端加载）
let categories: Category[] = [];
try {
  const categoriesRes = await categoryApi.getList();
  categories = categoriesRes.data || [];
} catch (error) {
  console.error('Failed to fetch categories:', error);
}

const selectedCategory = categoryId ? categories.find(c => c.id === categoryId) : null;

// Author Info
const author = {
  name: 'lililiz',
  bio: '全栈工程师 & AI应用工程师',
  avatar: '/images/image.png',
  paragraphs: [
    '一个热爱技术与创造的开发者，专注于 Java 后端、AI 应用与智能 Agent 系统方向。正在探索如何让 AI 不只是"回答问题"，而是真正具备长期记忆、自主行为与成长能力。',
    '擅长 Spring Boot、Spring Cloud、Redis、MySQL 等后端技术栈，同时也在深入研究大模型、向量数据库、Agent 架构、Prompt Engineering 与 AI 系统设计。热衷于将复杂技术拆解为通俗易懂的内容，对底层原理、系统架构与工程实践保持持续探索。',
    '目前正在构建多个 AI 与 Agent 相关项目，包括具备自主发帖、评论、成长机制的 AI 社区，以及融合天气监测、风险预警与智能助手的环境预警系统。喜欢把"想法"真正落地成可运行的产品。相信技术不仅是代码，更是一种创造未来的能力。热爱学习，持续折腾，长期主义者。',
  ],
};

---

<Layout title={selectedCategory ? `${selectedCategory.name} - TECH::minimal` : 'TECH::minimal | Blog'}>
  <Header currentPath={Astro.url.pathname} />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 pt-16 sm:pt-24 pb-16 sm:pb-20">
    
    <!-- Profile Section -->
    <section class="mb-12 max-w-3xl">
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 sm:gap-6 mb-6">
        <img src={author.avatar} alt={author.name} class="w-16 h-16 sm:w-20 sm:h-20 rounded-full border border-slate-200 dark:border-slate-700 shadow-sm" />
        <div>
          <h1 class="text-2xl sm:text-3xl font-sans font-bold text-slate-900 dark:text-white">{author.name}</h1>
          <p class="text-slate-500 dark:text-slate-400 font-sans text-base sm:text-lg">{author.bio}</p>
        </div>
      </div>
      <div class="space-y-4">
        {author.paragraphs.map(p => (
          <p class="text-slate-700 dark:text-slate-300 leading-relaxed font-serif text-base sm:text-lg">
            {p}
          </p>
        ))}
      </div>
    </section>

    <!-- Projects Section -->
    <section class="mb-16 max-w-3xl">
      <h2 class="font-sans text-lg font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-2">
        <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
        Featured Projects
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a
          href="https://www.lililiz.top/pulse"
          target="_blank"
          rel="noopener noreferrer"
          class="group block p-5 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 hover:shadow-md hover:-translate-y-1 transition-all duration-300"
        >
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-violet-500 to-purple-600 flex items-center justify-center text-white text-lg font-bold shrink-0">
              P
            </div>
            <div>
              <h3 class="font-sans font-bold text-slate-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                Pulse
              </h3>
              <p class="text-xs text-slate-400 dark:text-slate-500 font-mono">Spring Boot / AI Agent / LLM</p>
            </div>
          </div>
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed font-serif">具备自主发帖、评论、成长机制的 AI 社区。AI Agent 可以像真人一样参与社区讨论、发表观点，并随着时间推移不断"成长"与"进化"。</p>
        </a>
        <a
          href="https://www.lililiz.top/environment"
          target="_blank"
          rel="noopener noreferrer"
          class="group block p-5 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 hover:shadow-md hover:-translate-y-1 transition-all duration-300"
        >
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center text-white text-lg font-bold shrink-0">
              E
            </div>
            <div>
              <h3 class="font-sans font-bold text-slate-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                Environment
              </h3>
              <p class="text-xs text-slate-400 dark:text-slate-500 font-mono">Spring Boot / IoT / AI 预警</p>
            </div>
          </div>
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed font-serif">融合天气监测、风险预警与智能助手的环境预警系统。实时采集环境数据，结合 AI 分析实现智能预警与决策辅助。</p>
        </a>
      </div>
    </section>

    <div class="flex flex-col lg:flex-row gap-16">
      
      <!-- Articles List (Main Content) - Client-side with loading -->
      <div class="flex-1">
        <ArticleList client:load page={page} pageSize={pageSize} categoryId={categoryId} />
      </div>

      <!-- Right Sidebar (Categories) -->
      <aside class="w-full lg:w-72">
        <div class="sticky top-32">
          <h3 class="font-sans font-bold text-slate-900 dark:text-white mb-6 uppercase tracking-wide flex items-center gap-2">
            <span class="w-2 h-2 bg-slate-900 dark:bg-white rounded-full"></span>
            Categories
          </h3>
          <ul class="flex flex-col gap-2 font-sans">
            <li>
              <a href="/" class={`transition-all inline-block flex w-full items-center justify-between border-b border-slate-100 dark:border-slate-800 pb-3 ${!categoryId ? 'text-blue-600 dark:text-blue-400 font-medium' : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:translate-x-1'}`}>
                <span>All Articles</span>
              </a>
            </li>
            {categories.map(cat => (
              <li>
                <a href={`/?category=${cat.id}`} class={`transition-all inline-block flex w-full items-center justify-between border-b border-slate-100 dark:border-slate-800 pb-3 ${categoryId === cat.id ? 'text-blue-600 dark:text-blue-400 font-medium' : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:translate-x-1'}`}>
                  <span>{cat.name}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </aside>
      
    </div>
  </main>

  <Footer />
</Layout>
