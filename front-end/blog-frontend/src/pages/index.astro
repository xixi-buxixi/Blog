---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

// Dummy data for the presentation
const author = {
  name: 'Alex Developer',
  bio: 'Frontend Architect & UI Enthusiast',
  avatar: 'https://i.pravatar.cc/150?u=a042581f4e29026704d'
};

const post = {
  title: 'BUILDING REACT APPS WITH HOOKS & CONTEXT API',
  date: 'OCT 24, 2023',
  readTime: '8 MIN READ',
  content: `
    <p>React Hooks completely transformed how we build components by allowing us to use state and other React features without writing a class. When combined with the Context API, you can manage global state in a clean, minimal way that avoids the boilerplate of external libraries like Redux for many use cases.</p>
    
    <h3>The Power of useState and useEffect</h3>
    <p>The most common hooks you'll use are <code>useState</code> for local state management and <code>useEffect</code> for side effects like data fetching or DOM manipulation.</p>
    
    <pre><code class="language-jsx hljs">
<span class="hljs-keyword">import</span> React, { useState, useEffect } <span class="hljs-keyword">from</span> <span class="hljs-string">'react'</span>;

<span class="hljs-keyword">function</span> <span class="hljs-title">UserProfile</span>({ userId }) {
  <span class="hljs-keyword">const</span> [user, setUser] = <span class="hljs-title">useState</span>(<span class="hljs-literal">null</span>);
  <span class="hljs-keyword">const</span> [loading, setLoading] = <span class="hljs-title">useState</span>(<span class="hljs-literal">true</span>);

  <span class="hljs-title">useEffect</span>(() => {
    <span class="hljs-keyword">async</span> <span class="hljs-keyword">function</span> <span class="hljs-title">fetchUser</span>() {
      <span class="hljs-keyword">const</span> response = <span class="hljs-keyword">await</span> <span class="hljs-title">fetch</span>(<span class="hljs-string">\`/api/users/\${userId}\`</span>);
      <span class="hljs-keyword">const</span> data = <span class="hljs-keyword">await</span> response.<span class="hljs-title">json</span>();
      <span class="hljs-title">setUser</span>(data);
      <span class="hljs-title">setLoading</span>(<span class="hljs-literal">false</span>);
    }
    <span class="hljs-title">fetchUser</span>();
  }, [userId]);

  <span class="hljs-keyword">if</span> (loading) <span class="hljs-keyword">return</span> &lt;<span class="hljs-tag">div</span>&gt;Loading...&lt;/<span class="hljs-tag">div</span>&gt;;
  <span class="hljs-keyword">return</span> &lt;<span class="hljs-tag">div</span>&gt;{user.name}&lt;/<span class="hljs-tag">div</span>&gt;;
}
    </code></pre>
    
    <h3>Global State with Context</h3>
    <p>For state that needs to be accessed by many components at different nesting levels, Context API provides a way to pass data through the component tree without having to pass props down manually at every level.</p>
  `
};

const categories = ['Frontend Development', 'React', 'Architecture', 'UI/UX Design', 'Performance'];
const tags = ['JavaScript', 'Hooks', 'Context', 'Web', 'React Native', 'TypeScript', 'CSS-in-JS'];
---

<Layout title="TECH::minimal | React Hooks & Context">
  <Header currentPath="/" />
  
  <main class="max-w-7xl mx-auto px-6 pt-32 pb-24">
    <div class="flex flex-col lg:flex-row gap-16">
      
      <!-- Central Content Area -->
      <article class="flex-1 max-w-3xl">
        <header class="mb-10">
          <h1 class="text-4xl md:text-5xl font-sans font-bold text-slate-900 leading-tight mb-8 tracking-tight uppercase">
            {post.title}
          </h1>
          
          <div class="flex items-center justify-between border-t border-b border-slate-100 py-4">
            <div class="flex items-center gap-4">
              <img src={author.avatar} alt={author.name} class="w-12 h-12 rounded-full border border-slate-200" />
              <div>
                <div class="font-sans font-semibold text-slate-900">{author.name}</div>
                <div class="text-sm text-slate-500 font-sans">{author.bio}</div>
              </div>
            </div>
            <div class="text-right font-sans text-sm text-slate-500">
              <div class="font-medium text-slate-900">{post.date}</div>
              <div>{post.readTime}</div>
            </div>
          </div>
        </header>
        
        <div class="prose prose-lg max-w-none" set:html={post.content}></div>
      </article>

      <!-- Right Sidebar -->
      <aside class="w-full lg:w-80 flex flex-col gap-10">
        
        <!-- Subscribe Form -->
        <div class="bg-slate-50 border border-slate-200 rounded-xl p-6 shadow-sm">
          <h3 class="font-sans font-bold text-slate-900 mb-2 uppercase tracking-wide">Subscribe to Newsletter</h3>
          <p class="text-slate-600 font-sans text-sm mb-4">Get the latest articles and tutorials delivered straight to your inbox.</p>
          <form class="flex flex-col gap-3" onsubmit="event.preventDefault();">
            <input 
              type="email" 
              placeholder="Your email address" 
              class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 font-sans bg-white text-slate-800"
              required
            />
            <button 
              type="submit" 
              class="w-full bg-slate-900 hover:bg-slate-800 text-white font-sans font-medium py-2 rounded-lg transition-colors cursor-pointer"
            >
              SUBSCRIBE
            </button>
          </form>
        </div>

        <!-- Categories -->
        <div>
          <h3 class="font-sans font-bold text-slate-900 mb-4 uppercase tracking-wide flex items-center gap-2">
            <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
            Categories
          </h3>
          <ul class="flex flex-col gap-2 font-sans">
            {categories.map(cat => (
              <li>
                <a href={`/category/${cat.toLowerCase()}`} class="text-slate-600 hover:text-blue-600 hover:translate-x-1 transition-all inline-block flex w-full items-center justify-between border-b border-slate-100 pb-2">
                  <span>{cat}</span>
                  <span class="text-xs text-slate-400 bg-slate-100 px-2 py-0.5 rounded-full">12</span>
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Tags Word Cloud -->
        <div>
          <h3 class="font-sans font-bold text-slate-900 mb-4 uppercase tracking-wide flex items-center gap-2">
            <span class="w-2 h-2 bg-orange-500 rounded-full"></span>
            Tags
          </h3>
          <div class="flex flex-wrap gap-2 font-sans">
            {tags.map(tag => (
              <a 
                href={`/tag/${tag.toLowerCase()}`} 
                class="px-3 py-1 bg-slate-100 border border-slate-200 text-slate-600 text-sm rounded-md hover:bg-blue-50 hover:text-blue-600 hover:border-blue-200 transition-colors"
              >
                {tag}
              </a>
            ))}
          </div>
        </div>

      </aside>
      
    </div>
  </main>
</Layout>