---
// 首页 - SYS.LOG 风格
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Pagination from '../components/Pagination.astro';
import { articleApi, categoryApi, type Article, type Category } from '../utils/api';

// 获取查询参数
const url = new URL(Astro.request.url);
const page = parseInt(url.searchParams.get('page') || '1');
const categoryId = url.searchParams.get('category') ? parseInt(url.searchParams.get('category')!) : undefined;
const pageSize = 9;

// 获取文章列表和分类列表
let articles: Article[] = [];
let categories: Category[] = [];
let total = 0;
let totalPages = 1;

try {
  const [articlesRes, categoriesRes] = await Promise.all([
    articleApi.getList({ page, pageSize, categoryId }),
    categoryApi.getList()
  ]);
  articles = articlesRes.data.records;
  total = articlesRes.data.total;
  totalPages = articlesRes.data.pages;
  categories = categoriesRes.data;
} catch (error) {
  console.error('Failed to fetch data:', error);
}

const selectedCategory = categoryId ? categories.find(c => c.id === categoryId) : null;
---

<Layout title={selectedCategory ? `${selectedCategory.name} - SYS.LOG` : 'SYS.LOG | Engineering Blog'}>
  <Header currentPath={Astro.url.pathname} />

  <main class="flex-1 w-full pt-32 pb-20">
    
    <!-- Hero Section -->
    <header class="max-w-6xl mx-auto px-6 mb-32 relative">
      <div class="flex flex-col gap-6 relative z-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-primary/30 bg-primary/10 text-primary text-xs font-mono w-max backdrop-blur-sm">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
          </span>
          LATEST: ARCHITECTURE PATTERNS 2026
        </div>
        
        <h1 class="font-display text-5xl md:text-8xl font-bold leading-[1.1] tracking-tighter reveal-text">
          <span>Engineering</span><br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary animate-gradient-x">Beyond Limits.</span>
        </h1>
        
        <p class="text-zinc-400 text-lg md:text-xl max-w-2xl font-light leading-relaxed mt-4">
          Deep dives into systems design, performance optimization, and the bleeding edge of web technologies. Written for engineers, by engineers.
        </p>
      </div>
      
      <!-- Decorative Code Element -->
      <div class="absolute right-0 top-0 hidden lg:block w-96 h-96 opacity-20 pointer-events-none animate-float select-none">
        <pre class="text-xs font-mono text-secondary leading-tight">
<span class="text-primary">function</span> <span class="text-white">optimize</span>(system) {'{'}
  <span class="text-primary">while</span> (system.isRunning) {'{'}
    <span class="text-zinc-500">// Check bottlenecks</span>
    <span class="text-primary">const</span> metric = system.analyze();
    
    <span class="text-primary">if</span> (metric.latency > THRESHOLD) {'{'}
      system.scale(strategy.DISTRIBUTED);
      system.cache.invalidate();
    {'}'}
    
    <span class="text-primary">await</span> system.tick();
  {'}'}
{'}'}
        </pre>
      </div>
    </header>

    <!-- Articles Section -->
    <section class="max-w-6xl mx-auto px-6">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 border-b border-white/10 pb-6 gap-6">
        <h2 class="font-display text-3xl font-bold">Recent Dispatches</h2>
        
        <div class="flex flex-wrap items-center gap-4">
          <a
            href="/"
            class={`font-mono text-xs tracking-widest uppercase transition-colors hover-trigger px-3 py-1.5 rounded-full border ${
              !categoryId
                ? 'border-primary text-primary bg-primary/10'
                : 'border-white/10 text-zinc-400 hover:text-white hover:border-white/30'
            }`}
          >
            All
          </a>
          {categories.map((category) => (
            <a
              href={`/?category=${category.id}`}
              class={`font-mono text-xs tracking-widest uppercase transition-colors hover-trigger px-3 py-1.5 rounded-full border ${
                categoryId === category.id
                  ? 'border-secondary text-secondary bg-secondary/10'
                  : 'border-white/10 text-zinc-400 hover:text-white hover:border-white/30'
              }`}
            >
              {category.name}
            </a>
          ))}
        </div>
      </div>

      <!-- Article Grid -->
      {articles?.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {articles.map((article, index) => (
            <ArticleCard article={article} index={index} />
          ))}
        </div>
      ) : (
        <div class="text-center py-32 glass rounded-2xl">
          <p class="font-mono text-zinc-500 tracking-widest uppercase text-xl">No dispatches found</p>
          {!categoryId && (
            <p class="text-primary text-sm mt-4 font-mono">System might be offline.</p>
          )}
        </div>
      )}

      <!-- Pagination -->
      {totalPages > 1 && (
        <div class="mt-20 border-t border-white/10 pt-10">
          <Pagination
            currentPage={page}
            totalPages={totalPages}
            baseUrl={categoryId ? `/?category=${categoryId}` : '/'}
          />
        </div>
      )}
    </section>

    <!-- Newsletter Section -->
    <section class="max-w-6xl mx-auto px-6 mt-32">
      <div class="glass border border-primary/20 rounded-3xl p-8 md:p-16 relative overflow-hidden text-center">
        <!-- Glows -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-gradient-to-r from-primary/20 to-secondary/20 blur-3xl -z-10 pointer-events-none"></div>
        
        <h2 class="font-display text-3xl md:text-5xl font-bold mb-4">Stay in the Loop</h2>
        <p class="text-zinc-400 max-w-xl mx-auto mb-8">Get deep engineering insights delivered straight to your inbox. No spam, only high-quality technical content.</p>
        
        <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto relative z-10" onsubmit="event.preventDefault();">
          <input type="email" placeholder="jane@company.com" class="flex-1 bg-black/50 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors hover-trigger placeholder:text-zinc-600 font-sans">
          <button type="submit" class="bg-white text-black font-medium px-6 py-3 rounded-xl hover:bg-zinc-200 transition-colors hover-trigger">Subscribe</button>
        </form>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  // Simple text reveal animation on load
  const initReveal = () => {
    const reveals = document.querySelectorAll('.reveal-text');
    // small timeout to ensure css is loaded and transition happens
    setTimeout(() => {
      reveals.forEach(r => r.classList.add('active'));
    }, 100);
  };
  
  initReveal();
  document.addEventListener('astro:page-load', initReveal);
</script>