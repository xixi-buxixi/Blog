---
// 搜索页 - SYS.LOG 风格
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Pagination from '../components/Pagination.astro';
import { articleApi, type Article } from '../utils/api';

// 获取搜索参数
const url = new URL(Astro.request.url);
const keyword = url.searchParams.get('q') || '';
const page = parseInt(url.searchParams.get('page') || '1');
const pageSize = 9;

// 搜索文章
let articles: Article[] = [];
let total = 0;
let totalPages = 1;

if (keyword) {
  try {
    const res = await articleApi.search(keyword, page, pageSize);
    articles = res.data.records;
    total = res.data.total;
    totalPages = res.data.pages;
  } catch (error) {
    console.error('Search failed:', error);
  }
}
---

<Layout title={keyword ? `Search: ${keyword} | SYS.LOG` : 'Search | SYS.LOG'}>
  <Header currentPath="/search" />

  <main class="flex-1 w-full pt-32 pb-20">
    <div class="max-w-6xl mx-auto px-6">
      <!-- Search Input -->
      <div class="mb-16 border-b border-white/10 pb-8 max-w-2xl mx-auto text-center">
        <h1 class="font-display text-4xl font-bold mb-8">Query Database</h1>
        <form action="/search" method="get" class="relative group">
          <input
            type="text"
            name="q"
            value={keyword}
            placeholder="Enter search parameters..."
            class="w-full bg-surface/50 border border-white/10 rounded-2xl px-6 py-4 pl-14 text-white focus:outline-none focus:border-primary focus:bg-surface/80 transition-all shadow-sm hover-trigger font-mono placeholder:text-zinc-600"
            autocomplete="off"
          />
          <svg class="w-6 h-6 text-zinc-500 absolute left-5 top-1/2 -translate-y-1/2 group-focus-within:text-primary transition-colors pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <button
            type="submit"
            class="absolute right-3 top-1/2 -translate-y-1/2 px-4 py-2 bg-white/5 hover:bg-white/10 text-white text-sm font-mono rounded-xl transition-colors hover-trigger"
          >
            EXECUTE
          </button>
        </form>
      </div>

      <!-- Search Results -->
      {keyword && (
        <div class="mb-8 font-mono text-sm text-zinc-500 flex items-center justify-between">
          <p>
            RESULTS FOR: <span class="text-white">"{keyword}"</span>
          </p>
          <p>
            [<span class="text-primary">{total}</span> RECORDS FOUND]
          </p>
        </div>
      )}

      <!-- Results List -->
      {keyword ? (
        articles.length > 0 ? (
          <>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
              {articles.map((article, index) => (
                <ArticleCard article={article} index={index} />
              ))}
            </div>

            <!-- Pagination -->
            {totalPages > 1 && (
              <div class="mt-20 border-t border-white/10 pt-10">
                <Pagination
                  currentPage={page}
                  totalPages={totalPages}
                  baseUrl={`/search?q=${encodeURIComponent(keyword)}`}
                />
              </div>
            )}
          </>
        ) : (
          <div class="glass rounded-2xl p-16 text-center border-dashed border-white/10 mt-8">
            <p class="font-mono text-zinc-500 text-lg mb-2">0 RESULTS RETURNED</p>
            <p class="text-zinc-600 font-sans text-sm">Refine your search parameters and try again.</p>
          </div>
        )
      ) : (
        <div class="glass rounded-2xl p-16 text-center border-dashed border-white/10 mt-8">
          <div class="w-16 h-16 rounded-full bg-white/5 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <p class="font-mono text-zinc-400">AWAITING QUERY INPUT...</p>
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>