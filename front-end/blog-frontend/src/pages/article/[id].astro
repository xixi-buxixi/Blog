---
// 文章详情页 - SYS.LOG 风格
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CommentSection from '../../components/CommentSection.astro';
import { articleApi, type Article } from '../../utils/api';

// 获取文章 ID
const { id } = Astro.params;
const articleId = parseInt(id || '0');

// 获取文章详情
let article: Article | null = null;
let error: string | null = null;

if (articleId) {
  try {
    const res = await articleApi.getDetail(articleId);
    article = res.data;
  } catch (e) {
    error = '文章不存在或已被删除';
  }
}

// 格式化日期
const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).toUpperCase();
};
---

<Layout title={article ? `${article.title} | SYS.LOG` : 'Article Not Found | SYS.LOG'} description={article?.summary}>
  <Header currentPath="/article" />

  <main class="flex-1 w-full pt-32 pb-20">
    {article ? (
      <article class="max-w-4xl mx-auto px-6">
        <!-- 文章头部 -->
        <header class="mb-12">
          <!-- 分类 -->
          <div class="mb-6 flex items-center gap-3">
            <a
              href={`/?category=${article.categoryId}`}
              class="inline-flex items-center px-3 py-1 rounded bg-white/5 text-primary text-xs font-mono font-bold uppercase tracking-wider hover:bg-primary/20 transition-colors hover-trigger"
            >
              {article.categoryName || 'GENERAL'}
            </a>
            <span class="text-zinc-500 text-xs font-mono flex items-center gap-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              {article.viewCount} READS
            </span>
          </div>

          <!-- 标题 -->
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-display font-bold text-white mb-6 leading-tight tracking-tight break-words overflow-hidden">
            {article.title}
          </h1>

          <!-- 元信息 -->
          <div class="flex flex-wrap items-center gap-6 text-sm text-zinc-400 font-mono border-t border-b border-white/10 py-4">
            <span class="flex items-center space-x-2">
              <span class="w-2 h-2 rounded-full bg-secondary"></span>
              <span>AUTHOR: {article.authorName || 'SYSTEM'}</span>
            </span>
            <span class="flex items-center space-x-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <time datetime={article.createTime}>{formatDate(article.createTime)}</time>
            </span>
          </div>
        </header>

        <!-- 封面图 -->
        {article.coverImage && (
          <div class="mb-12 rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-primary/5">
            <img
              src={article.coverImage}
              alt={article.title}
              class="w-full h-auto object-cover max-h-[60vh]"
            />
          </div>
        )}

        <!-- 文章内容 -->
        <div class="glass rounded-3xl p-6 sm:p-10 md:p-12 mb-16 relative">
          <!-- decorative glow -->
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-primary/20 rounded-full blur-3xl pointer-events-none"></div>
          
          <div id="article-content" class="prose max-w-none relative z-10" data-content={article.content}>
            <!-- 内容将由客户端 JS 渲染 -->
          </div>
        </div>

        <!-- 评论区 -->
        <div data-article-id={articleId}>
          <CommentSection articleId={articleId} />
        </div>

        <!-- 文章底部 -->
        <footer class="mt-16 flex items-center justify-between border-t border-white/10 pt-8">
          <a
            href="/"
            class="inline-flex items-center text-zinc-400 hover:text-white font-mono text-sm transition-colors hover-trigger"
          >
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            RETURN TO HOME
          </a>
        </footer>
      </article>
    ) : (
      <div class="max-w-3xl mx-auto px-6 py-32 text-center">
        <div class="glass rounded-3xl p-16 border-dashed border-white/10 inline-block">
          <div class="w-20 h-20 rounded-full bg-white/5 flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
          </div>
          <h1 class="font-display text-3xl font-bold text-white mb-2">RECORD NOT FOUND</h1>
          <p class="text-zinc-400 font-mono text-sm mb-8">{error || 'The requested file might be deleted or does not exist.'}</p>
          <a
            href="/"
            class="inline-flex items-center px-6 py-3 bg-white/5 border border-white/10 text-white rounded-xl hover:bg-white/10 transition-colors font-mono hover-trigger"
          >
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            RETURN TO SYSTEM ROOT
          </a>
        </div>
      </div>
    )}
  </main>

  <Footer />
</Layout>

{article && (
  <script define:vars={{ article }}>
    // 使用 CDN 加载库，避免裸模块名导入问题
    const renderMarkdown = async () => {
      const loadScript = (url) => {
        return new Promise((resolve, reject) => {
          const script = document.createElement('script');
          script.src = url;
          script.onload = resolve;
          script.onerror = reject;
          document.head.appendChild(script);
        });
      };

      try {
        await Promise.all([
          loadScript('https://cdn.jsdelivr.net/npm/marked/marked.min.js'),
          loadScript('https://cdn.jsdelivr.net/npm/dompurify/dist/purify.min.js'),
          loadScript('https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11/build/highlight.min.js')
        ]);

        const languages = ['javascript', 'typescript', 'python', 'java', 'go', 'rust',
                           'css', 'json', 'sql', 'bash', 'markdown', 'yaml'];
        for (const lang of languages) {
          try {
            await loadScript(`https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11/build/languages/${lang}.min.js`);
          } catch (e) {
          }
        }

        marked.setOptions({
          highlight: function(code, lang) {
            if (lang && hljs.getLanguage(lang)) {
              try {
                return hljs.highlight(code, { language: lang }).value;
              } catch (e) {}
            }
            return hljs.highlightAuto(code).value;
          },
          breaks: true,
          gfm: true,
        });

        const contentEl = document.getElementById('article-content');
        if (contentEl) {
          const rawContent = contentEl.dataset.content || '';
          const html = marked.parse(rawContent);
          const cleanHtml = DOMPurify.sanitize(html);
          contentEl.innerHTML = cleanHtml;
        }
      } catch (e) {
        const contentEl = document.getElementById('article-content');
        if (contentEl) {
          contentEl.textContent = contentEl.dataset.content || '';
        }
      }
    };

    renderMarkdown();
  </script>
)}