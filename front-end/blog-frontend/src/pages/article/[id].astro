---
// 文章详情页
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CommentSection from '../../components/CommentSection.astro';
import { articleApi, type Article } from '../../utils/api';

// 获取文章 ID
const { id } = Astro.params;
const articleId = parseInt(id || '0');

// 获取文章详情
let article: Article | null = null;
let error: string | null = null;

if (articleId) {
  try {
    const res = await articleApi.getDetail(articleId);
    article = res.data;
  } catch (e) {
    error = '文章不存在或已被删除';
  }
}

// 格式化日期
const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};

// 预览代码高亮函数
const highlightCode = (code: string, lang: string) => {
  // 简单的代码高亮标记，实际渲染时会由 highlight.js 处理
  return code;
};
---

<Layout title={article ? `${article.title} - My Blog` : '文章详情 - My Blog'} description={article?.summary}>
  <Header currentPath="/article" />

  <main class="flex-1 bg-gray-50">
    {article ? (
      <article class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
        <!-- 文章头部 -->
        <header class="mb-8">
          <!-- 分类 -->
          <div class="mb-4">
            <a
              href={`/?category=${article.categoryId}`}
              class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-primary-50 text-primary-600 hover:bg-primary-100 transition-colors"
            >
              {article.categoryName}
            </a>
          </div>

          <!-- 标题 -->
          <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4 leading-tight">
            {article.title}
          </h1>

          <!-- 元信息 -->
          <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
            <span class="flex items-center space-x-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              <span>{article.authorName}</span>
            </span>
            <span class="flex items-center space-x-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <time datetime={article.createTime}>{formatDate(article.createTime)}</time>
            </span>
            <span class="flex items-center space-x-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
              <span>{article.viewCount} 阅读</span>
            </span>
          </div>
        </header>

        <!-- 封面图 -->
        {article.coverImage && (
          <div class="mb-8 rounded-xl overflow-hidden">
            <img
              src={article.coverImage}
              alt={article.title}
              class="w-full h-auto"
            />
          </div>
        )}

        <!-- 文章内容 -->
        <div class="bg-white rounded-xl border border-gray-100 p-6 sm:p-8">
          <div id="article-content" class="prose max-w-none" data-content={article.content}>
            <!-- 内容将由客户端 JS 渲染 -->
          </div>
        </div>

        <!-- 评论区 -->
        <div data-article-id={articleId}>
          <CommentSection articleId={articleId} />
        </div>

        <!-- 文章底部 -->
        <footer class="mt-8 flex items-center justify-between">
          <a
            href="/"
            class="inline-flex items-center text-primary-600 hover:text-primary-700 font-medium"
          >
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            返回首页
          </a>
        </footer>
      </article>
    ) : (
      <div class="max-w-4xl mx-auto px-4 sm:px-6 py-16 text-center">
        <svg class="w-20 h-20 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h1 class="text-xl font-semibold text-gray-700 mb-2">文章不存在</h1>
        <p class="text-gray-500 mb-6">{error || '您访问的文章可能已被删除或不存在'}</p>
        <a
          href="/"
          class="inline-flex items-center px-4 py-2 bg-primary-500 text-white rounded-lg hover:bg-primary-600 transition-colors"
        >
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          返回首页
        </a>
      </div>
    )}
  </main>

  <Footer />
</Layout>

{article && (
  <script define:vars={{ article }}>
    // 使用 CDN 加载库，避免裸模块名导入问题
    const renderMarkdown = async () => {
      // 从 CDN 动态加载库
      const loadScript = (url) => {
        return new Promise((resolve, reject) => {
          const script = document.createElement('script');
          script.src = url;
          script.onload = resolve;
          script.onerror = reject;
          document.head.appendChild(script);
        });
      };

      // 加载必要的库
      try {
        await Promise.all([
          loadScript('https://cdn.jsdelivr.net/npm/marked/marked.min.js'),
          loadScript('https://cdn.jsdelivr.net/npm/dompurify/dist/purify.min.js'),
          loadScript('https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11/build/highlight.min.js')
        ]);

        // 加载常用语言包
        const languages = ['javascript', 'typescript', 'python', 'java', 'go', 'rust',
                           'css', 'json', 'sql', 'bash', 'markdown', 'yaml'];
        for (const lang of languages) {
          try {
            await loadScript(`https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11/build/languages/${lang}.min.js`);
          } catch (e) {
            // 语言包不存在则跳过
          }
        }

        // 配置 marked
        marked.setOptions({
          highlight: function(code, lang) {
            if (lang && hljs.getLanguage(lang)) {
              try {
                return hljs.highlight(code, { language: lang }).value;
              } catch (e) {
                console.error(e);
              }
            }
            return hljs.highlightAuto(code).value;
          },
          breaks: true,
          gfm: true,
        });

        // 渲染 Markdown
        const contentEl = document.getElementById('article-content');
        if (contentEl) {
          const rawContent = contentEl.dataset.content || '';
          const html = marked.parse(rawContent);
          const cleanHtml = DOMPurify.sanitize(html);
          contentEl.innerHTML = cleanHtml;
        }
      } catch (e) {
        console.error('Failed to load markdown libraries:', e);
        // 显示原始内容作为后备
        const contentEl = document.getElementById('article-content');
        if (contentEl) {
          contentEl.textContent = contentEl.dataset.content || '';
        }
      }
    };

    // 页面加载完成后执行
    renderMarkdown();
  </script>
)}