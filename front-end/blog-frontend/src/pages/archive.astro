---
// 归档页 - SYS.LOG 风格
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { archiveApi, articleApi, type Article } from '../utils/api';

// 获取归档数据
interface ArchiveGroup {
  year: number;
  months: {
    month: number;
    articles: Article[];
  }[];
}

let archiveData: ArchiveGroup[] = [];

try {
  const res = await articleApi.getList({ current: 1, size: 100 });
  const articles = res.data.records;

  const groupedByYear = articles.reduce((acc, article) => {
    const date = new Date(article.createTime);
    const year = date.getFullYear();
    const month = date.getMonth() + 1;

    if (!acc[year]) acc[year] = {};
    if (!acc[year][month]) acc[year][month] = [];
    acc[year][month].push(article);

    return acc;
  }, {} as Record<number, Record<number, Article[]>>);

  archiveData = Object.keys(groupedByYear)
    .map(Number)
    .sort((a, b) => b - a)
    .map(year => ({
      year,
      months: Object.keys(groupedByYear[year])
        .map(Number)
        .sort((a, b) => b - a)
        .map(month => ({
          month,
          articles: groupedByYear[year][month]
        }))
    }));
} catch (error) {
  console.error('Failed to fetch archive data:', error);
}

const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }).toUpperCase();
};

const monthNames = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN', 'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'];
---

<Layout title="Archive | SYS.LOG">
  <Header currentPath="/archive" />

  <main class="flex-1 w-full pt-32 pb-20">
    <div class="max-w-4xl mx-auto px-6">
      <div class="mb-16 border-b border-white/10 pb-8">
        <h1 class="font-display text-4xl md:text-6xl font-bold mb-4">System Archive</h1>
        <p class="text-zinc-400 font-mono text-sm">/var/log/sys.log - Historical records</p>
      </div>

      {archiveData.length > 0 ? (
        <div class="space-y-16 relative">
          {/* Vertical line connecting timeline */}
          <div class="absolute left-[11px] top-4 bottom-4 w-px bg-white/10 hidden md:block"></div>
          
          {archiveData.map((yearGroup) => (
            <div class="relative">
              <div class="flex items-baseline mb-8 sticky top-20 z-10 bg-background/80 backdrop-blur py-4 md:pl-10">
                <span class="font-display text-3xl font-bold text-primary">{yearGroup.year}</span>
                <span class="ml-4 font-mono text-xs text-zinc-500">
                  [{yearGroup.months.reduce((sum, m) => sum + m.articles.length, 0)} ENTRIES]
                </span>
                {/* Timeline node */}
                <div class="absolute left-0 top-1/2 -translate-y-1/2 w-6 h-6 rounded-full bg-background border border-primary/30 flex items-center justify-center hidden md:flex">
                  <div class="w-2 h-2 rounded-full bg-primary animate-pulse"></div>
                </div>
              </div>

              <div class="space-y-12 md:pl-10">
                {yearGroup.months.map((monthGroup) => (
                  <div>
                    <h3 class="font-mono text-secondary mb-6 flex items-center gap-4">
                      {monthNames[monthGroup.month - 1]}
                      <span class="h-px bg-white/5 flex-1"></span>
                    </h3>

                    <div class="space-y-4">
                      {monthGroup.articles.map((article) => (
                        <a
                          href={`/article/${article.id}`}
                          class="group block glass rounded-xl p-5 hover-trigger hover:-translate-y-1 transition-all border border-white/5 hover:border-primary/30 hover:bg-white/[0.02]"
                        >
                          <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                            <div class="flex-1 min-w-0">
                              <h4 class="font-display text-lg font-bold text-zinc-200 group-hover:text-primary transition-colors truncate mb-1">
                                {article.title}
                              </h4>
                              {article.summary && (
                                <p class="text-zinc-500 text-sm line-clamp-1 font-light">{article.summary}</p>
                              )}
                            </div>
                            
                            <div class="flex items-center gap-4 text-xs font-mono text-zinc-500 shrink-0">
                              <span class="px-2 py-1 rounded bg-white/5 text-zinc-400">
                                {article.categoryName || 'GENERAL'}
                              </span>
                              <time class="w-16 text-right">
                                {formatDate(article.createTime)}
                              </time>
                            </div>
                          </div>
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="glass rounded-2xl p-12 text-center border-dashed border-white/10">
          <p class="font-mono text-zinc-500">404 - NO RECORDS FOUND</p>
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>