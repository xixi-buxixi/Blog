---
// 分类列表页 - SYS.LOG 风格
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { categoryApi, type Category } from '../../utils/api';

// 获取分类列表
let categories: Category[] = [];

try {
  const res = await categoryApi.getList();
  categories = res.data;
} catch (error) {
  console.error('Failed to fetch categories:', error);
}
---

<Layout title="Categories | SYS.LOG">
  <Header currentPath="/category" />

  <main class="flex-1 w-full pt-32 pb-20">
    <div class="max-w-6xl mx-auto px-6">
      <!-- 页面标题 -->
      <div class="mb-16 border-b border-white/10 pb-8">
        <h1 class="font-display text-4xl md:text-6xl font-bold mb-4">System Categories</h1>
        <p class="text-zinc-400 font-mono text-sm">/var/lib/categories - {categories.length} MODULES DETECTED</p>
      </div>

      <!-- 分类卡片 -->
      {categories.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {categories.map((category) => (
            <a
              href={`/?category=${category.id}`}
              class="group glass rounded-2xl p-6 hover-trigger hover:-translate-y-2 transition-all duration-300 border border-white/5 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/10"
            >
              <div class="flex items-start justify-between">
                <div class="flex-1">
                  <h2 class="font-display text-2xl font-bold text-zinc-100 group-hover:text-primary transition-colors mb-2">
                    {category.name}
                  </h2>
                  {category.description && (
                    <p class="text-zinc-400 text-sm font-light line-clamp-2">{category.description}</p>
                  )}
                </div>
                <div class="ml-4 flex-shrink-0 flex flex-col items-center">
                  <div class="w-12 h-12 rounded-full bg-white/5 group-hover:bg-primary/20 transition-colors flex items-center justify-center font-mono">
                    <span class="text-primary font-bold">{category.articleCount}</span>
                  </div>
                  <p class="text-[10px] text-zinc-500 font-mono mt-2 uppercase">ENTRIES</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="glass rounded-2xl p-16 text-center border-dashed border-white/10 mt-8">
          <p class="font-mono text-zinc-500 text-lg mb-2">0 MODULES DETECTED</p>
          <p class="text-zinc-600 font-sans text-sm">No categories available in the system.</p>
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>