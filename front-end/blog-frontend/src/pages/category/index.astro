---
// 分类列表页
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { categoryApi, type Category } from '../../utils/api';

// 获取分类列表
let categories: Category[] = [];

try {
  const res = await categoryApi.getList();
  categories = res.data;
} catch (error) {
  console.error('Failed to fetch categories:', error);
}
---

<Layout title="分类 - My Blog">
  <Header currentPath="/category" />

  <main class="flex-1 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
      <!-- 页面标题 -->
      <div class="mb-8">
        <h1 class="text-2xl font-bold text-gray-900">全部分类</h1>
        <p class="text-gray-500 mt-1">共 {categories.length} 个分类</p>
      </div>

      <!-- 分类卡片 -->
      {categories.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {categories.map((category) => (
            <a
              href={`/category/${category.id}`}
              class="group bg-white rounded-xl border border-gray-100 p-5 hover:shadow-lg hover:border-primary-100 transition-all duration-300"
            >
              <div class="flex items-start justify-between">
                <div class="flex-1">
                  <h2 class="text-lg font-semibold text-gray-900 group-hover:text-primary-600 transition-colors">
                    {category.name}
                  </h2>
                  {category.description && (
                    <p class="text-gray-500 text-sm mt-1 line-clamp-2">{category.description}</p>
                  )}
                </div>
                <div class="ml-4 flex-shrink-0">
                  <div class="w-12 h-12 rounded-lg bg-primary-50 flex items-center justify-center">
                    <span class="text-primary-600 font-semibold">{category.articleCount}</span>
                  </div>
                  <p class="text-xs text-gray-400 text-center mt-1">文章</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="bg-white rounded-xl border border-gray-100 p-12 text-center">
          <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
          </svg>
          <p class="text-gray-500">暂无分类</p>
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>